{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 60 }
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/server.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control",    "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",           "value": "no-cache" },
        { "key": "Expires",         "value": "0" },
        { "key": "Surrogate-Control","value": "no-store" }
      ]
    }
  ]
}
