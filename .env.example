ANTHROPIC_API_KEY=your_anthropic_key_here

# Supabase — create a project at https://supabase.com
# Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Web Push / VAPID keys — generate once with:
#   node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
# Keys are permanent: rotating them invalidates ALL existing push subscriptions.
# Add the same three vars to Vercel → Project Settings → Environment Variables.
VAPID_PUBLIC_KEY=your_vapid_public_key_base64url_here
VAPID_PRIVATE_KEY=your_vapid_private_key_base64url_here
VAPID_EMAIL=mailto:you@example.com

# /api/push/test gate — set any random secret string here and in Vercel.
# Pass it as header  x-test-push-secret: <value>  when calling the test endpoint.
# NODE_ENV is always "production" on Vercel so we use this header instead.
TEST_PUSH_SECRET=your_random_secret_here

PORT=3000
